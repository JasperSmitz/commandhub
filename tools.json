[
  {
    "name": "echo",
    "description": "Echo a message",
    "command": "cmd.exe",
    "arguments": [
      "/c",
      "echo",
      "{message}"
    ],
    "parameters": [
      {
        "name": "message",
        "type": "string",
        "required": true
      }
    ],
    "timeout": 5000
  },
  {
    "name": "java-version",
    "description": "Show installed Java version",
    "command": "cmd.exe",
    "arguments": [
      "/c",
      "java",
      "-version"
    ],
    "parameters": [],
    "timeout": 5000
  }
]